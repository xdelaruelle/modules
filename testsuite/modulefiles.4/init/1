#%Module
if {[info exists env(TESTSUITE_INIT_ENVVARS)]} {
    switch -- $env(TESTSUITE_INIT_ENVVARS) {
        append1 {
            append-path FOO value
        }
        prepend1 {
            prepend-path FOO value
        }
        remove1 {
            remove-path FOO value
        }
        setenv1 {
            setenv FOO value
        }
        unsetenv1 {
            unsetenv FOO
        }
        pushenv1 {
            pushenv FOO value
        }
        append_dup1 {
            append-path --duplicates FOO value
        }
    }
}
