#%Module

module-whatis [module-info name]

if {[info exists env(TESTSUITE_LCOMPAT)]} {
    switch -- $env(TESTSUITE_LCOMPAT) {
        haveDynamicMPATH1 {
            haveDynamicMPATH
        }
        haveDynamicMPATH2 {
            haveDynamicMPATH foo bar
        }
        depon_spec1 {
            depends-on bar/1 foo=val1
        }
        allo_spec1 {
            always-load bar/1 foo=val1
        }
        prall_spec1 {
            prereq-all bar/1 foo=val1
        }
    }
}
